# OS files
.DS_Store
Thumbs.db

# macOS
.DS_Store
**/.DS_Store

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Secrets and local environment
.env
.env.*
!.env.example
wp-config.php
wp-config-local.php
*.pem
*.key
*.crt

# Archives and backups
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bak
*.backup

# Database exports
*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.dump

# Frontend dependencies and build output
node_modules/
.next/
out/
coverage/

# Raw Bible source data archives
/docs/data-sources/
/docs/data-sources/**/*.mdb
/docs/data-sources/**/*.sqlite
/docs/data-sources/**/*.db
/docs/data-sources/**/*.zip
/docs/data-sources/**/*.xml
/docs/data-sources/**/*.json
/docs/data-sources/**/*.generated.json

# Local WP runtime files
/backend/conf/
/backend/logs/
/backend/run/
/backend/sql/
/backend/app/sql/

# WordPress generated content inside Local WP
/backend/app/public/wp-content/uploads/
/backend/app/public/wp-content/cache/
/backend/app/public/wp-content/upgrade/
/backend/app/public/wp-content/debug.log

# Ignore Local WP WordPress core while keeping the official plugin source tracked.
/backend/app/public/*
!/backend/app/public/wp-content/
/backend/app/public/wp-content/*
!/backend/app/public/wp-content/plugins/
/backend/app/public/wp-content/plugins/*
!/backend/app/public/wp-content/plugins/wcm-core/
!/backend/app/public/wp-content/plugins/wcm-core/**
/backend/app/public/wp-content/plugins/wcm-core/vendor/
/backend/app/public/wp-content/plugins/wcm-core/node_modules/

# Word Covenant Ministry generated data / local migration artifacts
backups/
storage/exports/
storage/imports/

docs/data-packages/**/*.jsonl
docs/data-packages/**/*.sql
docs/data-packages/**/*.zip
docs/data-packages/**/*.tar
docs/data-packages/**/*.gz
docs/data-packages/**/*.sha256.generated
docs/data-packages/**/generated/

backend/app/public/wp-content/plugins/wcm-core/*.sql
backend/app/public/wp-content/plugins/wcm-core/**/*.sql

# Allow documentation and tiny examples
!docs/data-packages/**/README.md
!docs/data-packages/**/manifest.example.json
!docs/data-packages/**/sample-*.jsonl
